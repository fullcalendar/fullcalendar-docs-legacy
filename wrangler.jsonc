{
  // The stock Ruby in Cloudflare Workers Builds is pinned in .ruby-version
  // to avoid compiling Ruby on every build.
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fullcalendar-docs-legacy",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "./_site",
    "html_handling": "drop-trailing-slash"
  },
  "preview_urls": true,
  "routes": [
    {
      "pattern": "legacy.fullcalendar.io",
      "custom_domain": true
    }
  ]
}
